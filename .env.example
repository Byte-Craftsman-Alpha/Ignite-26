# SQLite database path (relative to project root)
SQLITE_DB_PATH=./data/ignite26.db

# Admin login credentials (loaded by API server on startup)
ADMIN_EMAIL=admin@ignite26.edu.in
ADMIN_PASSWORD=change-me-strong-password

# SMTP configuration (used for OTP + registration confirmation emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
SMTP_FROM=Ignite 26 <your-email@example.com>

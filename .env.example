# SQLite database path (relative to project root)
SQLITE_DB_PATH=./data/ignite26.db
API_BODY_LIMIT=25mb
PUBLIC_SITE_URL=https://ignite26.teamparadox.in

# Admin login credentials (loaded by API server on startup)
ADMIN_EMAIL=admin@ignite26.edu.in
ADMIN_PASSWORD=change-me-strong-password

# Public event social links (used in website footer)
VITE_EVENT_WHATSAPP_URL=https://wa.me/919999999999
VITE_EVENT_INSTAGRAM_URL=https://instagram.com/ignite26

# SMTP configuration (used for OTP + registration confirmation emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
SMTP_FROM=Ignite 26 <your-email@example.com>

# Google Sheet sync (optional)
# Accepts normal Google Sheet URL or direct CSV export URL.
GOOGLE_SHEET_SYNC_URL=
# Shared secret for webhook-based push sync from Google Apps Script.
SHEET_SYNC_SECRET=
